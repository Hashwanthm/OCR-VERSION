// CHECKOUT FORM DATA
// =====================================================

function getCheckoutFormData() {
  return {
    name: document.getElementById("customerName").value.trim(),
    phone: document.getElementById("customerPhone").value.trim(),
    city: document.getElementById("customerCity").value.trim(),
    address: document.getElementById("customerAddress").value.trim(),
    paymentMethod: document.getElementById("paymentMethod").value
  };
}


// =====================================================
// VALIDATION ERROR OBJECT
// =====================================================

function validateCheckoutForm(formData) {
  const errors = {};

  if (formData.name === "") {
    errors.name = "Customer name is required";
  }

  if (formData.phone.length !== 10) {
    errors.phone = "Phone number must be 10 digits";
  }

  if (formData.city === "") {
    errors.city = "City is required";
  }

  if (formData.address === "") {
    errors.address = "Address is required";
  }

  if (formData.paymentMethod === "") {
    errors.paymentMethod = "Payment method is required";
  }

  return errors;
}


function displayFormErrors(errors) {
  const formErrors = document.getElementById("formErrors");
  const errorKeys = Object.keys(errors);

  if (errorKeys.length === 0) {
    formErrors.innerHTML = "";
    return;
  }

  formErrors.innerHTML = Object.entries(errors)
    .map(function ([field, message]) {
      return `<p><strong>${field}:</strong> ${message}</p>`;
    })
    .join("");
}


// =====================================================
// PLACE ORDER
// =====================================================

function placeOrder() {
  if (cart.length === 0) {
    showMessage("Cart is empty");
    return;
  }

  const formData = getCheckoutFormData();
  const errors = validateCheckoutForm(formData);
  displayFormErrors(errors);

  if (Object.keys(errors).length > 0) {
    return;
  }

  const customer = {
    name: formData.name,
    phone: formData.phone,

    address: {
      city: formData.city,
      fullAddress: formData.address
    }
  };

  const payment = {
    method: formData.paymentMethod,
    status: formData.paymentMethod === "Cash on Delivery" ? "Pending" : "Success",
    transactionId: formData.paymentMethod === "Cash on Delivery"
      ? null
      : "TXN" + Date.now()
  };

  const delivery = {
    courierName: "BlueDart",
    trackingId: "BD" + Date.now(),
    status: "Processing",
    expectedDeliveryDays: 4
  };

  const subtotal = calculateSubtotal();
  const discount = calculateDiscount(subtotal);
  const finalAmount = subtotal - discount;

  const totals = {
    subtotal: subtotal,
    discount: discount,
    finalAmount: finalAmount
  };

  const orderItems = cart.map(function (item) {
    return { ...item };
  });

  const order = new Order(
    customer,
    orderItems,
    payment,
    delivery,
    totals
  );

  order.updateStatus("Confirmed");

  const orderJSON = JSON.stringify(order, null, 2);

  localStorage.setItem("latestOrder", orderJSON);

  const savedOrder = JSON.parse(localStorage.getItem("latestOrder"));

  document.getElementById("orderOutput").textContent =
    JSON.stringify(savedOrder, null, 2);

  cart = [];
  appState.appliedCoupon = null;
  document.getElementById("couponInput").value = "";

  saveCartToLocalStorage();
  displayCart();
  displayProducts();

  showMessage("Order placed successfully");
}


// =====================================================
// LOCALSTORAGE
// =====================================================

function saveCartToLocalStorage() {
  localStorage.setItem("cart", JSON.stringify(cart));
}


function loadCartFromLocalStorage() {
  const savedCart = localStorage.getItem("cart");

  if (savedCart) {
    cart = JSON.parse(savedCart);
  }
}


// =====================================================
// SYNC INVENTORY AFTER PAGE REFRESH
// =====================================================

function syncInventoryWithCart() {
  cart.forEach(function (cartItem) {
    const product = products.find(function (item) {
      return item.id === cartItem.id;
    });

    if (!product) {
      return;
    }

    product.inventory.availableQuantity =
      product.inventory.availableQuantity - cartItem.quantity;

    if (product.inventory.availableQuantity <= 0) {
      product.inventory.availableQuantity = 0;
      product.inStock = false;
    }
  });
}


// =====================================================
// INITIAL PAGE LOAD
// =====================================================

function initApp() {
  loadCartFromLocalStorage();
  syncInventoryWithCart();
  loadCategories();
  displayProducts();
  displayCart();
}

initApp();