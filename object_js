// =====================================================
// ADD TO CART
// =====================================================

function addToCart(productId) {
  const selectedProduct = products.find(function (product) {
    return product.id === productId;
  });

  if (!selectedProduct) {
    showMessage("Product not found");
    return;
  }

  const inventory = inventoryMap.get(productId);

  if (inventory.availableQuantity <= 0) {
    selectedProduct.inStock = false;
    displayProducts();
    showMessage("Product is out of stock");
    return;
  }

  const existingCartItem = cart.find(function (item) {
    return item.id === productId;
  });

  if (existingCartItem) {
    existingCartItem.quantity++;
  } else {
    const {
      reviews,
      specs,
      seller,
      warranty,
      inventory,
      ...basicProductData
    } = selectedProduct;

    const cartItem = {
      ...basicProductData,
      quantity: 1,
      addedAt: new Date().toISOString()
    };

    cart.push(cartItem);
  }

  inventory.availableQuantity--;

  if (inventory.availableQuantity === 0) {
    selectedProduct.inStock = false;
  }

  displayProducts();
  displayCart();
}


// =====================================================
// DISPLAY CART
// =====================================================

function displayCart() {
  const cartItems = document.getElementById("cartItems");
  const cartCount = document.getElementById("cartCount");

  cartCount.textContent = cart.reduce(function (count, item) {
    return count + item.quantity;
  }, 0);

  if (cart.length === 0) {
    cartItems.innerHTML = `<p>Your cart is empty.</p>`;
    updateTotals();
    saveCartToLocalStorage();
    return;
  }

  cartItems.innerHTML = cart
    .map(function (item) {
      return `
        <div class="border rounded p-3">
          <h4 class="font-bold">${item.name}</h4>

          <p>Price: ${store.formatPrice(item.price)}</p>
          <p>Quantity: ${item.quantity}</p>

          <p class="font-bold">
            Subtotal: ${store.formatPrice(item.price * item.quantity)}
          </p>

          <div class="flex gap-2 mt-2">
            <button onclick="increaseQuantity(${item.id})" class="bg-green-600 text-white px-2 py-1 rounded">
              +
            </button>

            <button onclick="decreaseQuantity(${item.id})" class="bg-yellow-500 text-white px-2 py-1 rounded">
              -
            </button>

            <button onclick="removeFromCart(${item.id})" class="bg-red-600 text-white px-2 py-1 rounded">
              Remove
            </button>
          </div>
        </div>
      `;
    })
    .join("");

  updateTotals();
  saveCartToLocalStorage();
}


// =====================================================
// CART TOTALS
// =====================================================

function calculateSubtotal() {
  return cart.reduce(function (sum, item) {
    return sum + item.price * item.quantity;
  }, 0);
}


function calculateDiscount(subtotal) {
  if (!appState.appliedCoupon) {
    return 0;
  }

  return appState.appliedCoupon.calculateDiscount(subtotal);
}


function updateTotals() {
  const subtotal = calculateSubtotal();
  const discount = calculateDiscount(subtotal);
  const finalAmount = subtotal - discount;

  document.getElementById("subtotalAmount").textContent = subtotal;
  document.getElementById("discountAmount").textContent = discount;
  document.getElementById("finalAmount").textContent = finalAmount;
}


// =====================================================
// INCREASE QUANTITY
// =====================================================

function increaseQuantity(productId) {
  const item = cart.find(function (cartItem) {
    return cartItem.id === productId;
  });

  const product = products.find(function (productItem) {
    return productItem.id === productId;
  });

  const inventory = inventoryMap.get(productId);

  if (inventory.availableQuantity <= 0) {
    showMessage("No more stock available");
    return;
  }

  item.quantity++;
  inventory.availableQuantity--;

  if (inventory.availableQuantity === 0) {
    product.inStock = false;
  }

  displayProducts();
  displayCart();
}


// =====================================================
// DECREASE QUANTITY
// =====================================================

function decreaseQuantity(productId) {
  const item = cart.find(function (cartItem) {
    return cartItem.id === productId;
  });

  const product = products.find(function (productItem) {
    return productItem.id === productId;
  });

  const inventory = inventoryMap.get(productId);

  if (item.quantity > 1) {
    item.quantity--;
    inventory.availableQuantity++;
    product.inStock = true;
  } else {
    removeFromCart(productId);
    return;
  }

  displayProducts();
  displayCart();
}


// =====================================================
// REMOVE FROM CART
// =====================================================

function removeFromCart(productId) {
  const removedItem = cart.find(function (item) {
    return item.id === productId;
  });

  const product = products.find(function (productItem) {
    return productItem.id === productId;
  });

  const inventory = inventoryMap.get(productId);

  if (removedItem) {
    inventory.availableQuantity += removedItem.quantity;
    product.inStock = true;
  }

  cart = cart.filter(function (item) {
    return item.id !== productId;
  });

  displayProducts();
  displayCart();
}


// =====================================================
// APPLY COUPON
// =====================================================

function applyCoupon() {
  const couponCode = document
    .getElementById("couponInput")
    .value
    .trim()
    .toUpperCase();

  const coupon = coupons[couponCode];

  if (!coupon) {
    appState.appliedCoupon = null;
    updateTotals();
    showMessage("Invalid coupon");
    return;
  }

  appState.appliedCoupon = coupon;
  updateTotals();
}


