<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />

  <!-- Makes website responsive on mobile and desktop -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Ecommerce Objects Practice</title>

  <!-- Tailwind CSS for quick styling -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen">

  <!-- HEADER -->
  <header class="bg-gray-900 text-white p-5">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold">Smart Shop</h1>
        <p class="text-gray-300">Ecommerce Website Using JavaScript Objects</p>
      </div>

      <div class="bg-white text-gray-900 px-4 py-2 rounded">
        Cart Items:
        <span id="cartCount" class="font-bold">0</span>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto p-5">

    <!-- SEARCH, FILTER, SORT -->
    <section class="bg-white p-5 rounded shadow mb-6">
      <h2 class="text-2xl font-bold mb-4">Products</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <input
          id="searchInput"
          oninput="handleSearch()"
          type="text"
          placeholder="Search product..."
          class="border p-3 rounded"
        />

        <select
          id="categoryFilter"
          onchange="handleCategoryFilter()"
          class="border p-3 rounded"
        >
          <option value="all">All Categories</option>
        </select>

        <select
          id="sortSelect"
          onchange="handleSort()"
          class="border p-3 rounded"
        >
          <option value="default">Default</option>
          <option value="price">Sort by Price</option>
          <option value="rating">Sort by Rating</option>
          <option value="name">Sort by Name</option>
        </select>

      </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- PRODUCT LIST -->
      <section class="lg:col-span-2 bg-white p-5 rounded shadow">
        <h2 class="text-2xl font-bold mb-4">Product List</h2>

        <div id="productList" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
      </section>

      <!-- CART -->
      <aside class="bg-white p-5 rounded shadow">
        <h2 class="text-2xl font-bold mb-4">Cart</h2>

        <div id="cartItems" class="space-y-3"></div>

        <hr class="my-4" />

        <p class="text-lg font-bold">
          Subtotal: ₹<span id="subtotalAmount">0</span>
        </p>

        <p class="text-lg font-bold text-green-700">
          Discount: ₹<span id="discountAmount">0</span>
        </p>

        <p class="text-xl font-bold mt-2">
          Final Total: ₹<span id="finalAmount">0</span>
        </p>

        <div class="mt-4">
          <input
            id="couponInput"
            type="text"
            placeholder="Try SAVE10"
            class="border p-3 rounded w-full"
          />

          <button
            onclick="applyCoupon()"
            class="bg-purple-600 text-white px-4 py-2 rounded mt-2 w-full"
          >
            Apply Coupon
          </button>
        </div>
      </aside>

    </div>

    <!-- PRODUCT DETAILS -->
    <section class="bg-white p-5 rounded shadow mt-6">
      <h2 class="text-2xl font-bold mb-4">Selected Product Details</h2>

      <div id="productDetails" class="text-gray-700">
        Click View Details on any product.
      </div>
    </section>

    <!-- CHECKOUT -->
    <section class="bg-white p-5 rounded shadow mt-6">
      <h2 class="text-2xl font-bold mb-4">Checkout</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <input
          id="customerName"
          type="text"
          placeholder="Customer name"
          class="border p-3 rounded"
        />

        <input
          id="customerPhone"
          type="text"
          placeholder="Phone number"
          class="border p-3 rounded"
        />

        <input
          id="customerCity"
          type="text"
          placeholder="City"
          class="border p-3 rounded"
        />

        <select id="paymentMethod" class="border p-3 rounded">
          <option value="">Select payment method</option>
          <option value="UPI">UPI</option>
          <option value="Card">Card</option>
          <option value="Cash on Delivery">Cash on Delivery</option>
        </select>

      </div>

      <textarea
        id="customerAddress"
        placeholder="Full address"
        class="border p-3 rounded w-full mt-4"
      ></textarea>

      <button
        onclick="placeOrder()"
        class="bg-green-600 text-white px-4 py-3 rounded mt-4"
      >
        Place Order
      </button>

      <div id="formErrors" class="text-red-600 mt-4"></div>
    </section>

    <!-- FINAL ORDER -->
    <section class="bg-white p-5 rounded shadow mt-6 mb-10">
      <h2 class="text-2xl font-bold mb-4">Final Order Details</h2>

      <pre
        id="orderOutput"
        class="bg-gray-900 text-green-300 p-4 rounded overflow-x-auto text-sm"
      ></pre>
    </section>

  </main>

  <script src="script.js"></script>
</body>
</html>